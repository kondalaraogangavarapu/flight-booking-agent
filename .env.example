# Flight Booking Agent – Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# Application
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=info

# Security – must be set in production
SECRET_KEY=

# Anthropic API key (optional – enables LLM-powered agent; omit for keyword-based demo mode)
ANTHROPIC_API_KEY=

# Gunicorn workers (Docker only)
WEB_CONCURRENCY=2
HEALTH_CHECK_TIMEOUT=5
